{
  "name": "dtrw-app-home",
  "version": "1.6.2",
  "repository": "git@github.com:burtek/dtrw-app-home.git",
  "author": "Bartosz <burtekdotryw@gmail.com>",
  "license": "MIT",
  "private": true,
  "dependencies": {},
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "standard-version": "^9.5.0",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel start:dev",
    "dev:ui": "pnpm --filter frontend start:dev",
    "build": "pnpm -r --parallel --aggregate-output --no-bail build",
    "lint": "pnpm -r --parallel --aggregate-output --no-bail lint",
    "test": "vitest run",
    "prepare": "husky",
    "release": "standard-version"
  },
  "standard-version": {
    "bumpFiles": [
      "package.json",
      "packages/backend/package.json",
      "packages/frontend/package.json"
    ]
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
