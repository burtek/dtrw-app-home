{
  "name": "dtrw-app-home",
  "version": "1.6.1",
  "repository": "git@github.com:burtek/dtrw-app-home.git",
  "author": "Bartosz <burtekdotryw@gmail.com>",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {},
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "concurrently": "^10.0.3",
    "husky": "^9.1.7",
    "standard-version": "^9.5.0",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "dev": "concurrently yarn:dev:*",
    "dev:backend": "yarn workspace backend start:dev",
    "dev:frontend": "yarn workspace frontend start:dev",
    "build": "concurrently --group yarn:build:*",
    "build:backend": "yarn workspace backend build",
    "build:frontend": "yarn workspace frontend build",
    "lint": "concurrently --group yarn:lint:*",
    "lint:backend": "yarn workspace backend lint",
    "lint:frontend": "yarn workspace frontend lint",
    "test": "vitest run",
    "prepare": "husky",
    "release": "standard-version"
  },
  "standard-version": {
    "bumpFiles": [
      "package.json",
      "packages/backend/package.json",
      "packages/frontend/package.json"
    ]
  }
}
